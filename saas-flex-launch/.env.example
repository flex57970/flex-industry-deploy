# ================================================================
# FLEX Launch - Environment Variables
# ================================================================
# Copy this file to .env.local and fill in ALL values before running.
# NEVER commit .env.local to git.

# ----------------------------------------------------------------
# APP
# ----------------------------------------------------------------
# Public URL of your deployment. Use http://localhost:3000 in dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Application name displayed in emails, page titles, etc.
NEXT_PUBLIC_APP_NAME=FLEX Launch
# Node environment (development | production | test)
NODE_ENV=development

# ----------------------------------------------------------------
# DATABASE (Supabase Postgres)
# ----------------------------------------------------------------
# Full Postgres connection string (from Supabase → Settings → Database → Connection String → URI)
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flex_launch

# ----------------------------------------------------------------
# SUPABASE AUTH
# ----------------------------------------------------------------
# From Supabase → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# From Supabase → Settings → API → anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
# From Supabase → Settings → API → service_role key (NEVER expose client-side)
SUPABASE_SERVICE_ROLE_KEY=xxx

# ----------------------------------------------------------------
# STRIPE
# ----------------------------------------------------------------
# Test mode: sk_test_... / Live mode: sk_live_...
STRIPE_SECRET_KEY=sk_test_xxx
# Public key for client-side checkout
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# From Stripe CLI: `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Product price IDs created by `pnpm run setup:stripe`
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_AGENCY_MONTHLY=price_xxx

# ----------------------------------------------------------------
# OPENAI (Core feature: AI landing page generation)
# ----------------------------------------------------------------
OPENAI_API_KEY=sk-xxx
# Model used for generation
OPENAI_MODEL=gpt-4o-mini

# ----------------------------------------------------------------
# RESEND (Transactional emails)
# ----------------------------------------------------------------
RESEND_API_KEY=re_xxx
# From email - MUST be on a domain verified in Resend
RESEND_FROM_EMAIL=FLEX Launch <noreply@flex-launch.com>
# Admin email for critical notifications
RESEND_ADMIN_EMAIL=contact@flex-industry.fr

# ----------------------------------------------------------------
# INNGEST (Background jobs)
# ----------------------------------------------------------------
# Leave empty for local dev (uses Inngest Dev Server on port 8288)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ----------------------------------------------------------------
# UPSTASH REDIS (Rate limiting)
# ----------------------------------------------------------------
# From Upstash → Console → Redis database → REST API
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ----------------------------------------------------------------
# ADMIN
# ----------------------------------------------------------------
# Comma-separated list of admin emails (access to /admin route)
ADMIN_EMAILS=contact@flex-industry.fr

# ----------------------------------------------------------------
# OBSERVABILITY (optional)
# ----------------------------------------------------------------
# Sentry DSN (leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=
# PostHog analytics (leave empty to disable)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
